    "axios": "^1.11.0",
    "cross-env": "^10.0.0",
    "fast-xml-parser": "^5.2.5",
    "libxml2-wasm": "0.6.0",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-gapcursor": "^1.3.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-keymap": "^1.2.3",
